<!DOCTYPE html>
<html>
  <head>
    <% default_title = "Elite Nails | Cramerton Nail Salon - Book Online" %>
    <%# Keep under ~155 chars: Google truncates past that, and the CTA is the
        first thing lost. Phone is omitted on purpose — the Business Profile
        panel already shows it directly above the search result.
        Named services are pending owner confirmation — see AGENTS.md
        "Pending Follow-Ups". %>
    <% default_description = "Family-owned in Cramerton since 2003. Manicures, pedicures, gel, dip, acrylics, and nail art. Walk-ins welcome or book online." %>
    <title><%= content_for(:title).presence || default_title %></title>
    <meta name="description" content="<%= content_for(:description).presence || default_description %>">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%# Lets analytics.js classify a booking-CTA click as native vs Square fallback. %>
    <meta name="booking-url" content="<%= booking_link %>">

    <%= render "shared/meta_tags", default_title: default_title, default_description: default_description %>
    <%= render "shared/structured_data" %>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&family=Cormorant+Garamond:wght@300;400;500;600&display=swap" rel="stylesheet">

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%# Filename is versioned on purpose: /icon.png is served with a ~1yr
        immutable cache header, so changing the artwork requires a new URL for
        caches (and Google's favicon crawler) to pick it up. Bump to -v3 etc.
        if the logo changes again. 480px = multiple of 48, per Google's guidance. %>
    <link rel="icon" href="/icon-v2.png" type="image/png" sizes="480x480">
    <link rel="icon" href="/favicon.ico" sizes="48x48 32x32 16x16">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="font-sans antialiased">
    <%= yield %>
  </body>
</html>
