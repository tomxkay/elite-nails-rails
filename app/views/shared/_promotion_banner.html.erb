<% promotion = Promotion.primary_for_display %>

<% if promotion %>
  <% promotion_href = booking_link %>
  <% promotion_headline = [ promotion.deal, promotion.title ].compact_blank.join(" ") %>
  <% mobile_headline = promotion.mobile_headline.presence || promotion_headline %>
  <% link_options = {} %>
  <% if promotion_href.start_with?("http") %>
    <% link_options[:target] = "_blank" %>
    <% link_options[:rel] = "noopener" %>
  <% end %>

  <div class="relative overflow-hidden border-b border-cream-200/80 bg-[linear-gradient(90deg,rgba(254,249,245,0.86),rgba(253,243,235,0.9),rgba(244,246,244,0.82))] backdrop-blur-xl">
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-terracotta-300/60 to-transparent" aria-hidden="true"></div>
    <div class="mx-auto flex max-w-7xl flex-col gap-1.5 px-4 py-1 sm:px-6 md:py-2 lg:flex-row lg:items-center lg:justify-between lg:gap-2 lg:px-8 lg:py-2.5">
      <div class="flex w-full min-w-0 items-start gap-3 lg:w-auto lg:items-center">
        <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-terracotta-700 text-cream-50 shadow-warm-sm md:h-8 md:w-8 lg:mt-0">
          <%= icon 'sparkles', classes: 'h-3 w-3 md:h-4 md:w-4' %>
        </span>
        <p class="min-w-0 text-sm leading-snug text-warm-gray-800">
          <span class="sr-only md:hidden">Current Special: </span>
          <span class="hidden font-semibold uppercase tracking-[0.16em] text-terracotta-700 md:inline">Current Special</span>
          <span class="mx-2 hidden text-terracotta-300 md:inline">/</span>
          <span class="block font-serif text-base leading-tight text-warm-gray-900 md:inline md:text-lg"><span class="hidden md:inline"><%= promotion_headline %></span><span class="promotion-mobile-headline block md:hidden"><%= mobile_headline %></span></span>
          <% if promotion.badge.present? %>
            <span class="ml-2 mt-0 hidden rounded-full border border-terracotta-200 bg-white/55 px-2.5 py-0.5 text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-terracotta-700 md:inline-flex"><%= promotion.badge %></span>
          <% end %>
        </p>
      </div>

      <div class="hidden w-full items-center justify-between gap-3 pl-11 md:flex md:flex-wrap md:gap-x-4 md:gap-y-1 lg:w-auto lg:flex-nowrap lg:pl-0">
        <% if promotion.fine_print.present? %>
          <span class="text-xs leading-snug text-warm-gray-600"><%= promotion.fine_print %></span>
        <% end %>
        <%= link_to promotion_href,
                    class: "inline-flex items-center gap-1.5 whitespace-nowrap text-xs font-semibold uppercase tracking-[0.16em] text-terracotta-700 transition-colors hover:text-terracotta-900",
                    **link_options do %>
          <span>Book & Save</span>
          <%= icon 'arrow-right', classes: 'h-3.5 w-3.5' %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
