<div data-controller="mobile-menu" data-action="keydown@window->mobile-menu#closeOnEscape resize@window->mobile-menu#closeForDesktop">
  <header id="navbar" data-controller="navbar" data-action="scroll@window->navbar#toggleLabel resize@window->navbar#toggleLabel" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-cream-50/80 backdrop-blur-md border-b border-cream-200/70 shadow-warm-sm">
    <%= render 'shared/promotion_banner' if controller_name == 'pages' && action_name == 'home' %>

    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Desktop Navigation -->
      <div class="hidden xl:flex items-center justify-center relative min-h-14 py-2" data-navbar-target="navRow">
        <!-- Left Nav Links -->
        <div class="flex items-center space-x-8 absolute left-0">
          <a href="<%= root_path(anchor: 'about') %>" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll" data-smooth-scroll-target-value="#about">About</a>
          <a href="<%= root_path(anchor: 'story') %>" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll" data-smooth-scroll-target-value="#story">Our Story</a>
          <a href="<%= root_path(anchor: 'services') %>" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll" data-smooth-scroll-target-value="#services">Services</a>
          <a href="<%= root_path(anchor: 'pricing') %>" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll" data-smooth-scroll-target-value="#pricing">Pricing</a>
          <a href="<%= root_path(anchor: 'testimonials') %>" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll" data-smooth-scroll-target-value="#testimonials">Reviews</a>
        </div>
        <!-- Centered Logo -->
        <div class="absolute left-1/2 top-1/2 z-10 -translate-x-1/2 -translate-y-1/2">
          <%= render 'shared/logo',
                     size: :header_large,
                     image: 'header-logo-250.webp',
                     image_classes: 'drop-shadow-[0_10px_24px_rgba(126,83,38,0.18)]',
                     collapsible_text: true %>
        </div>
        <!-- Right Nav Links -->
        <div class="flex items-center space-x-8 absolute right-0">
          <a href="<%= root_path(anchor: 'team') %>" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll" data-smooth-scroll-target-value="#team">Team</a>
          <a href="<%= root_path(anchor: 'contact') %>" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll" data-smooth-scroll-target-value="#contact">Contact</a>
          <%# Call and Book are one flex child so the nav's space-x-8 doesn't
              split the pair. Phone first — it's the salon's primary channel. %>
          <div class="flex items-center gap-2">
            <%= render 'shared/cta_button',
                       text: salon.phone_display,
                       href: "tel:#{salon.phone}",
                       style: :outline,
                       size: :sm,
                       icon: 'phone',
                       classes: 'text-xs' %>
            <%= render 'shared/cta_button',
                       text: 'Book Now',
                       href: booking_link,
                       style: :solid,
                       size: :sm,
                       classes: 'text-xs' %>
          </div>
        </div>
      </div>

      <!-- Mobile Navigation Header -->
      <div class="xl:hidden relative flex min-h-14 items-center justify-between py-2" data-navbar-target="navRow">
        <button type="button" id="mobileMenuBtn" class="p-2 -ml-2 text-warm-gray-700 hover:text-terracotta-600 transition-colors" aria-label="Toggle menu" aria-controls="mobileMenu" aria-expanded="false" data-mobile-menu-target="button" data-action="click->mobile-menu#open">
          <%= icon 'bars-3', classes: 'w-6 h-6' %>
        </button>
        <div class="absolute left-1/2 top-1/2 z-10 -translate-x-1/2 -translate-y-1/2">
          <%= render 'shared/logo',
                     size: :header_small,
                     image: 'header-logo-250.webp',
                     image_classes: 'drop-shadow-[0_8px_18px_rgba(126,83,38,0.16)]',
                     collapsible_text: true %>
        </div>
        <%# Tap-to-call sits beside Book in the mobile header. Icon-only to fit
            alongside the centered logo; the sticky bar carries the labelled
            version. %>
        <div class="flex items-center gap-1">
          <a href="tel:<%= salon.phone %>"
             class="p-2 text-terracotta-600 transition-colors hover:text-terracotta-700"
             aria-label="Call Elite Nails at <%= salon.phone_display %>">
            <%= icon 'phone', classes: 'w-5 h-5' %>
          </a>
          <%= render 'shared/cta_button',
                     text: 'Book',
                     href: booking_link,
                     style: :outline,
                     size: :sm,
                     classes: 'p-2 -mr-2 text-xs' %>
        </div>
      </div>
    </nav>
  </header>

  <%= render 'shared/mobile_menu' %>
</div>
