<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Desktop Navigation -->
    <div class="hidden lg:flex items-center justify-center py-4 relative">
      <!-- Left Nav Links -->
      <div class="flex items-center space-x-8 absolute left-0">
        <a href="#home" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600">Home</a>
        <a href="#services" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600">Services</a>
        <a href="#pricing" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600">Pricing</a>
        <a href="#gallery" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600">Gallery</a>
      </div>
      <!-- Centered Logo -->
      <%= render 'shared/logo', size: :large %>
      <!-- Right Nav Links -->
      <div class="flex items-center space-x-8 absolute right-0">
        <a href="#about" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600">About</a>
        <a href="#team" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600">Team</a>
        <a href="#testimonials" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600">Reviews</a>
        <a href="#contact" class="nav-link text-sm font-medium text-[#444]/80 tracking-wide uppercase transition-colors duration-200 hover:text-sage-600">Contact</a>
        <%= render 'shared/cta_button',
                   text: 'Book Now',
                   href: booking_link,
                   style: :solid,
                   size: :sm,
                   classes: 'text-xs' %>
      </div>
    </div>

    <!-- Mobile Navigation Header -->
    <div class="lg:hidden flex items-center justify-between py-4">
      <button type="button" id="mobileMenuBtn" class="p-2 -ml-2 text-[#444] hover:text-sage-600 transition-colors" aria-label="Toggle menu">
        <%= icon 'bars-3', classes: 'w-6 h-6' %>
      </button>
      <%= render 'shared/logo', size: :small %>
      <%= render 'shared/cta_button',
                 text: 'Book',
                 href: booking_link,
                 style: :outline,
                 size: :sm,
                 classes: 'p-2 -mr-2 text-xs' %>
    </div>
  </nav>

  <%= render 'shared/mobile_menu' %>
</header>
