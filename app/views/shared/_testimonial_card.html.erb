<%# Review card (Google-review styled)
  Locals:
    - quote: review text
    - name: reviewer name
    - rating: integer (default 5)
    - date: relative date string, e.g. "2 weeks ago" (optional)
    - source: where the review came from, e.g. "Google" (optional)
%>
<% rating = (local_assigns[:rating] || 5).to_i %>
<% date = local_assigns[:date] %>
<% source = local_assigns[:source] %>
<% initial = name.to_s.strip.first || "?" %>

<div class="mb-6 break-inside-avoid rounded-2xl border border-cream-200 bg-cream-50/90 p-7 shadow-warm-sm backdrop-blur transition-shadow duration-300 hover:shadow-warm-xl"
     data-controller="card-hover">
  <div class="flex items-center gap-3">
    <div class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full bg-peach-200 shadow-warm-sm">
      <span class="text-sm font-semibold text-terracotta-700"><%= initial %></span>
    </div>
    <div>
      <p class="font-semibold text-warm-gray-900"><%= name %></p>
      <% if date.present? %>
        <p class="text-xs text-warm-gray-500"><%= date %></p>
      <% end %>
    </div>
  </div>

  <div class="mt-4 flex" aria-label="<%= rating %> out of 5 stars">
    <% rating.times do %>
      <%= icon 'star', variant: :solid, classes: 'w-5 h-5 text-gold-500 drop-shadow-sm' %>
    <% end %>
  </div>

  <blockquote class="mt-4 leading-relaxed text-warm-gray-700">
    &ldquo;<%= quote %>&rdquo;
  </blockquote>

  <% if source.present? %>
    <p class="mt-5 flex items-center gap-1.5 text-xs uppercase tracking-[0.16em] text-warm-gray-400">
      <span class="h-1.5 w-1.5 rounded-full bg-sage-400"></span>
      Posted on <%= source %>
    </p>
  <% end %>
</div>
