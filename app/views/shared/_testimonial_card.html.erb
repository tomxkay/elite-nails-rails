<%# Testimonial card with rating stars
  Locals:
    - quote: review text
    - name: reviewer name
    - rating: integer (default 5)
%>
<% rating ||= 5 %>
<% initial = name.to_s.strip.first || "?" %>

<div class="card-surface-warm rounded-2xl p-8 shadow-warm-sm hover:shadow-warm-xl transition-shadow duration-300" data-controller="card-hover">
  <div class="mb-4" data-card-hover-target="icon">
    <%= icon 'quote', classes: 'w-8 h-8 text-terracotta-400' %>
  </div>
  <div class="flex mb-4">
    <% rating.to_i.times do %>
      <%= icon 'star', variant: :solid, classes: 'w-5 h-5 text-gold-500 drop-shadow-sm' %>
    <% end %>
  </div>
  <blockquote class="text-warm-gray-900 leading-relaxed mb-6 italic">
    "<%= quote %>"
  </blockquote>
  <div class="flex items-center">
    <div class="w-11 h-11 rounded-full bg-peach-200 flex items-center justify-center mr-3 shadow-warm-sm">
      <span class="text-terracotta-700 font-semibold text-sm"><%= initial %></span>
    </div>
    <span class="text-warm-gray-900 font-semibold"><%= name %></span>
  </div>
</div>
