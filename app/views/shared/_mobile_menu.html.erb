<!-- Mobile Menu Overlay -->
<div id="mobileOverlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[60] hidden opacity-0 transition-opacity duration-300 xl:hidden" data-mobile-menu-target="overlay" data-action="click->mobile-menu#close"></div>

<!-- Mobile Menu Drawer -->
<div id="mobileMenu" class="fixed top-0 left-0 h-dvh w-80 max-w-[85vw] bg-cream-50 shadow-2xl z-[70] transform -translate-x-full transition-transform duration-300 ease-out xl:hidden" data-mobile-menu-target="panel">
  <div class="flex flex-col h-full">
    <div class="flex items-center justify-between p-6 border-b border-cream-200">
      <span class="font-script text-lg text-warm-gray-800">Menu</span>
      <button type="button" id="closeMenuBtn" class="p-2 -mr-2 text-warm-gray-700 hover:text-terracotta-600 transition-colors" aria-label="Close menu" data-action="click->mobile-menu#close">
        <%= icon 'x-mark', classes: 'w-6 h-6' %>
      </button>
    </div>
    <nav class="flex-1 px-6 py-8 overflow-y-auto">
      <ul class="space-y-1">
        <li><a href="<%= root_path %>" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll click->mobile-menu#close" data-smooth-scroll-target-value="#home" data-smooth-scroll-native-value="true" data-turbo="false">Home</a></li>
        <li><a href="<%= root_path(anchor: 'story') %>" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll click->mobile-menu#close" data-smooth-scroll-target-value="#story" data-smooth-scroll-native-value="true" data-turbo="false">Our Story</a></li>
        <li><a href="<%= root_path(anchor: 'services') %>" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll click->mobile-menu#close" data-smooth-scroll-target-value="#services" data-smooth-scroll-native-value="true" data-turbo="false">Services</a></li>
        <li><a href="<%= root_path(anchor: 'pricing') %>" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll click->mobile-menu#close" data-smooth-scroll-target-value="#pricing" data-smooth-scroll-native-value="true" data-turbo="false">Pricing</a></li>
        <li><a href="<%= root_path(anchor: 'gallery') %>" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll click->mobile-menu#close" data-smooth-scroll-target-value="#gallery" data-smooth-scroll-native-value="true" data-turbo="false">Gallery</a></li>
        <li><a href="<%= root_path(anchor: 'about') %>" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll click->mobile-menu#close" data-smooth-scroll-target-value="#about" data-smooth-scroll-native-value="true" data-turbo="false">About</a></li>
        <li><a href="<%= root_path(anchor: 'team') %>" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll click->mobile-menu#close" data-smooth-scroll-target-value="#team" data-smooth-scroll-native-value="true" data-turbo="false">Team</a></li>
        <li><a href="<%= root_path(anchor: 'testimonials') %>" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll click->mobile-menu#close" data-smooth-scroll-target-value="#testimonials" data-smooth-scroll-native-value="true" data-turbo="false">Reviews</a></li>
        <li><a href="<%= root_path(anchor: 'contact') %>" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll click->mobile-menu#close" data-smooth-scroll-target-value="#contact" data-smooth-scroll-native-value="true" data-turbo="false">Contact</a></li>
      </ul>
    </nav>
    <div class="p-6 border-t border-cream-200 bg-cream-100">
      <%= render 'shared/cta_button',
                 text: 'Book Now',
                 href: booking_link,
                 style: :solid,
                 size: :md,
                 classes: 'w-full justify-center' %>
      <p class="mt-4 text-center text-sm text-warm-gray-700">
        <a href="tel:+17048249032" class="hover:text-terracotta-600 transition-colors">(704) 824-9032</a>
      </p>
    </div>
  </div>
</div>
