<!-- Mobile Menu Overlay -->
<div id="mobileOverlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[60] hidden opacity-0 transition-opacity duration-300 xl:hidden" data-mobile-menu-target="overlay" data-action="click->mobile-menu#close"></div>

<!-- Mobile Menu Drawer -->
<div id="mobileMenu" class="fixed top-0 right-0 h-dvh w-80 max-w-[85vw] bg-cream-50 shadow-2xl z-[70] transform translate-x-full transition-transform duration-300 ease-out xl:hidden" data-mobile-menu-target="panel">
  <div class="flex flex-col h-full">
    <div class="flex items-center justify-between p-6 border-b border-cream-200">
      <span class="font-script text-lg text-warm-gray-800">Menu</span>
      <button type="button" id="closeMenuBtn" class="p-2 -mr-2 text-warm-gray-700 hover:text-terracotta-600 transition-colors" aria-label="Close menu" data-action="click->mobile-menu#close">
        <%= icon 'x-mark', classes: 'w-6 h-6' %>
      </button>
    </div>
    <nav class="flex-1 px-6 py-8 overflow-y-auto">
      <ul class="space-y-1">
        <li><a href="#home" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->mobile-menu#close click->smooth-scroll#scroll">Home</a></li>
        <li><a href="#story" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->mobile-menu#close click->smooth-scroll#scroll">Our Story</a></li>
        <li><a href="#services" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->mobile-menu#close click->smooth-scroll#scroll">Services</a></li>
        <li><a href="#pricing" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->mobile-menu#close click->smooth-scroll#scroll">Pricing</a></li>
        <li><a href="#gallery" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->mobile-menu#close click->smooth-scroll#scroll">Gallery</a></li>
        <li><a href="#about" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->mobile-menu#close click->smooth-scroll#scroll">About</a></li>
        <li><a href="#team" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->mobile-menu#close click->smooth-scroll#scroll">Team</a></li>
        <li><a href="#testimonials" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->mobile-menu#close click->smooth-scroll#scroll">Reviews</a></li>
        <li><a href="#contact" class="mobile-link block py-3 text-warm-gray-800 hover:text-terracotta-600 font-medium tracking-wide transition-colors" data-controller="smooth-scroll" data-action="click->mobile-menu#close click->smooth-scroll#scroll">Contact</a></li>
      </ul>
    </nav>
    <div class="p-6 border-t border-cream-200 bg-cream-100">
      <%= render 'shared/cta_button',
                 text: 'Book Now',
                 href: booking_link,
                 style: :solid,
                 size: :md,
                 classes: 'w-full justify-center' %>
      <p class="mt-4 text-center text-sm text-warm-gray-700">
        <a href="tel:+17048249032" class="hover:text-terracotta-600 transition-colors">(704) 824-9032</a>
      </p>
    </div>
  </div>
</div>
