<%# Persistent mobile action bar.
    Two doors, equal weight: the salon takes most appointments by phone, so
    calling is a first-class action here rather than a fallback buried in the
    contact section. This bar is on screen for the whole mobile visit, which
    makes it the most important place for the phone number to exist.
    See docs/booking-adoption-notes.md. %>
<div class="fixed bottom-3 left-1/2 z-40 w-[92vw] max-w-md -translate-x-1/2 translate-y-4 opacity-0 drop-shadow-lg transition duration-300 pointer-events-none lg:hidden"
     data-controller="mobile-cta">
  <div class="flex items-center gap-2 rounded-full border border-sage-100 bg-white/90 p-2 backdrop-blur-md">
    <%= render 'shared/cta_button',
               text: 'Call',
               href: "tel:#{salon.phone}",
               style: :outline,
               size: :sm,
               icon: 'phone',
               classes: 'flex-1' %>
    <%= render 'shared/cta_button',
               text: 'Book Online',
               href: booking_link,
               style: :solid,
               size: :sm,
               icon: 'calendar-days',
               classes: 'flex-1' %>
  </div>
</div>
