<%# Compact team member card.
  Locals:
    - name: string (required)
    - role: string (required)
    - bio: string
    - quote: string (optional)
    - specialties: array of strings (optional)
    - bookable: boolean
    - image_url: string (optional)
    - index: integer (0-based)
%>
<% name = local_assigns[:name] %>
<% role = local_assigns[:role] %>
<% bio = local_assigns[:bio] %>
<% quote = local_assigns[:quote] %>
<% specialties = local_assigns[:specialties] || [] %>
<% bookable = local_assigns[:bookable] %>
<% image_url = local_assigns[:image_url] %>
<% index = local_assigns[:index] || 0 %>
<% number = format("%02d", index + 1) %>
<% first_name = name.to_s.split.first %>
<% initial = first_name.to_s[0] %>

<article class="card-surface-warm flex h-full flex-col rounded-2xl border border-cream-200/80 p-5 shadow-warm-sm"
         data-controller="scroll-reveal"
         data-scroll-reveal-animation-value="fadeInUp"
         data-scroll-reveal-delay-value="<%= (index % 3) * 0.08 %>">
  <div class="flex items-start gap-4">
    <div class="relative h-28 w-24 shrink-0 overflow-hidden rounded-t-full rounded-b-2xl bg-gradient-to-b from-peach-100 via-cream-100 to-sage-100 ring-1 ring-cream-200">
      <% if image_url.present? %>
        <img src="<%= image_url %>"
             alt="<%= name %>, <%= role %>"
             class="h-full w-full object-cover"
             loading="lazy" />
      <% else %>
        <div class="flex h-full w-full items-end justify-center">
          <%= icon "user", variant: :solid, classes: "h-20 w-20 -mb-3 text-terracotta-200" %>
        </div>
        <span class="absolute left-1/2 top-4 -translate-x-1/2 whitespace-nowrap text-[0.48rem] uppercase tracking-[0.18em] text-terracotta-600/70">Photo soon</span>
      <% end %>
    </div>

    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-3">
        <span class="font-serif text-2xl leading-none text-terracotta-300"><%= number %></span>
        <span class="h-px flex-1 bg-gradient-to-r from-terracotta-200 to-transparent"></span>
      </div>
      <h3 class="mt-3 font-serif text-3xl leading-tight text-warm-gray-900"><%= name %></h3>
      <p class="mt-1 text-xs font-semibold uppercase tracking-[0.14em] text-terracotta-700"><%= role %></p>
    </div>
  </div>

  <% if quote.present? %>
    <p class="mt-5 font-script text-xl leading-snug text-warm-gray-800">&ldquo;<%= quote %>&rdquo;</p>
  <% end %>

  <% if bio.present? %>
    <p class="mt-3 line-clamp-4 text-sm leading-relaxed text-warm-gray-700"><%= bio %></p>
  <% end %>

  <% if specialties.any? %>
    <div class="mt-5 flex flex-wrap gap-2">
      <% specialties.first(4).each do |spec| %>
        <span class="rounded-full border border-cream-200 bg-white/75 px-3 py-1 text-xs font-semibold text-terracotta-700 shadow-warm-sm backdrop-blur"><%= spec %></span>
      <% end %>
    </div>
  <% end %>

  <% if first_name.present? %>
    <div class="mt-auto pt-6">
      <% if bookable %>
        <%= render "shared/cta_button",
                   text: "Book with #{first_name}",
                   href: booking_link,
                   style: :outline,
                   size: :sm,
                   icon: "calendar-days",
                   classes: "w-full justify-center" %>
      <% else %>
        <div class="flex flex-col gap-2">
          <%= render "shared/cta_button",
                     text: "Call for #{first_name}",
                     href: "tel:#{salon.phone}",
                     style: :outline,
                     size: :sm,
                     icon: "phone",
                     classes: "w-full justify-center" %>
          <span class="text-center text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-warm-gray-600">Phone &amp; walk-in</span>
        </div>
      <% end %>
    </div>
  <% end %>
</article>
