<%# Team member card
  Locals:
    - name: string
    - role: string
    - bio: string
    - specialties: array of strings (optional)
    - image_url: string (optional)
%>
<% name = local_assigns[:name] %>
<% role = local_assigns[:role] %>
<% bio = local_assigns[:bio] %>
<% specialties = local_assigns[:specialties] || [] %>
<% image_url = local_assigns[:image_url] %>

<div class="group card-surface-warm rounded-3xl overflow-hidden shadow-warm-sm hover:shadow-warm-xl transition-all duration-300" data-controller="card-hover">
  <div class="relative aspect-[4/5] overflow-hidden">
    <% if image_url.present? %>
      <img src="<%= image_url %>"
           alt="<%= name %>"
           class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
           data-card-hover-target="icon"
           loading="lazy" />
    <% else %>
      <div class="absolute inset-0 bg-gradient-to-br from-peach-100 via-cream-100 to-sage-100 flex items-center justify-center">
        <%= icon 'user-circle', classes: 'w-14 h-14 text-terracotta-400' %>
      </div>
    <% end %>
    <div class="absolute inset-0 bg-gradient-to-t from-black/35 via-black/15 to-transparent"></div>
  </div>
  <div class="p-6 space-y-3">
    <div>
      <h3 class="font-serif text-2xl text-warm-gray-900"><%= name %></h3>
      <p class="text-terracotta-600 text-sm font-semibold uppercase tracking-[0.12em] mt-1"><%= role %></p>
    </div>
    <p class="text-warm-gray-700 text-sm leading-relaxed"><%= bio %></p>
    <% if specialties.any? %>
      <div class="flex flex-wrap gap-2">
        <% specialties.each do |spec| %>
          <span class="px-3 py-1 rounded-full bg-peach-100 text-terracotta-700 text-xs font-semibold border border-cream-200 shadow-warm-sm"><%= spec %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
