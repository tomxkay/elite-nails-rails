<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Owner Sign In · Elite Nails</title>
  <%= csrf_meta_tags %>
  <style>
    body { font-family: ui-sans-serif, system-ui, sans-serif; background: #fef9f5; color: #47433f;
           display: grid; place-items: center; min-height: 100vh; margin: 0; }
    .card { background: #fff; border: 1px solid #fdf3eb; border-radius: 20px; padding: 2.5rem;
            width: min(92vw, 380px); box-shadow: 0 18px 40px -20px rgba(212,154,138,.35); }
    h1 { font-size: 1.25rem; margin: 0 0 .25rem; }
    p.sub { color: #6f6760; font-size: .9rem; margin: 0 0 1.5rem; }
    label { display: block; font-size: .8rem; text-transform: uppercase; letter-spacing: .12em; color: #a8604e; margin-bottom: .4rem; }
    input[type=password] { width: 100%; padding: .7rem .8rem; border: 1px solid #ead7cf; border-radius: 10px;
                           font-size: 1rem; box-sizing: border-box; }
    button { margin-top: 1.25rem; width: 100%; padding: .75rem; background: #a8604e; color: #fef9f5;
             border: 0; border-radius: 999px; font-size: 1rem; font-weight: 600; cursor: pointer; }
    .alert { background: #f5ebe7; color: #8a4f40; padding: .6rem .8rem; border-radius: 10px;
             font-size: .85rem; margin-bottom: 1rem; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Elite Nails — Owner Sign In</h1>
    <p class="sub">Sign in to authorize your AI assistant.</p>
    <% if flash[:alert] %><div class="alert"><%= flash[:alert] %></div><% end %>
    <%= form_with url: "/owner/login", method: :post do |f| %>
      <%= hidden_field_tag :return_to, @return_to %>
      <label for="password">Password</label>
      <%= password_field_tag :password, nil, id: "password", autofocus: true, autocomplete: "current-password" %>
      <%= f.submit "Sign in" %>
    <% end %>
  </div>
</body>
</html>
