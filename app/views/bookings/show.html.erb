<% content_for(:title, "Book an Appointment | Elite Nails · Cramerton, NC") %>
<% content_for(:description, "Book a manicure, pedicure, gel, dip, or nail art appointment at Elite Nails in Cramerton, NC.") %>

<%= render "shared/navigation" %>

<main class="page-with-fixed-header-offset min-h-screen bg-cream-50 pb-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <%= render "shared/section_header",
               eyebrow: "Book Online",
               title: "Reserve Your Appointment",
               subtitle: "Pick a service and a time that suits you — we'll take care of the rest." %>

    <% if @error %>
      <div class="mt-10 rounded-2xl border border-terracotta-200 bg-white p-6 text-center shadow-warm">
        <p class="text-warm-gray-700">We couldn't load online booking right now (<%= @error %>).</p>
        <p class="mt-2 text-warm-gray-600">
          Please call us at
          <a href="tel:<%= salon.phone %>" class="font-medium text-terracotta-600 underline underline-offset-4"><%= salon.phone_display %></a>
          and we'll get you booked.
        </p>
      </div>
    <% elsif @services.empty? %>
      <div class="mt-10 rounded-2xl border border-cream-200 bg-white p-6 text-center shadow-warm">
        <p class="text-warm-gray-700">Online booking is being set up.</p>
        <p class="mt-2 text-warm-gray-600">
          Call <a href="tel:<%= salon.phone %>" class="font-medium text-terracotta-600 underline underline-offset-4"><%= salon.phone_display %></a>
          to book your visit today.
        </p>
      </div>
    <% else %>
      <div data-controller="booking"
           data-booking-availability-url-value="<%= book_path %>/availability"
           data-booking-create-url-value="<%= book_path %>"
           class="mt-10 space-y-8">

        <!-- Step 1: Service -->
        <section class="rounded-3xl bg-white p-6 sm:p-8 shadow-warm border border-cream-200">
          <h2 class="font-serif text-xl text-warm-gray-800 mb-4"><span class="text-terracotta-500 mr-2">1.</span>Choose a service</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            <% @services.each do |service| %>
              <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-cream-200 p-4 transition-colors hover:border-peach-300 has-[:checked]:border-terracotta-500 has-[:checked]:bg-cream-100">
                <input type="radio" name="service" class="mt-1 accent-terracotta-500"
                       data-action="booking#serviceChanged"
                       data-booking-target="service"
                       value="<%= service[:id] %>"
                       data-version="<%= service[:version] %>"
                       data-name="<%= service[:name] %>">
                <span>
                  <span class="block font-medium text-warm-gray-800"><%= service[:name] %></span>
                  <span class="block text-sm text-warm-gray-600">
                    <%= service[:price] %><% if service[:duration_minutes].to_i.positive? %> · <%= service[:duration_minutes] %> min<% end %>
                  </span>
                </span>
              </label>
            <% end %>
          </div>
        </section>

        <!-- Step 2: Tech + day -->
        <section class="rounded-3xl bg-white p-6 sm:p-8 shadow-warm border border-cream-200">
          <h2 class="font-serif text-xl text-warm-gray-800 mb-4"><span class="text-terracotta-500 mr-2">2.</span>Pick your technician &amp; day</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="booking-staff" class="mb-1 block text-sm font-medium text-warm-gray-700">Technician</label>
              <select id="booking-staff" data-booking-target="staff" data-action="booking#loadSlots"
                      class="w-full rounded-xl border border-cream-200 bg-white px-3 py-2.5 text-warm-gray-800">
                <option value="">Anyone available</option>
                <% @staff.each do |member| %>
                  <option value="<%= member[:id] %>"><%= member[:name] %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label for="booking-date" class="mb-1 block text-sm font-medium text-warm-gray-700">Day</label>
              <input id="booking-date" type="date" data-booking-target="date" data-action="booking#loadSlots"
                     min="<%= Date.current.iso8601 %>" value="<%= Date.current.iso8601 %>"
                     class="w-full rounded-xl border border-cream-200 bg-white px-3 py-2.5 text-warm-gray-800">
            </div>
          </div>
        </section>

        <!-- Step 3: Time -->
        <section class="rounded-3xl bg-white p-6 sm:p-8 shadow-warm border border-cream-200">
          <h2 class="font-serif text-xl text-warm-gray-800 mb-4"><span class="text-terracotta-500 mr-2">3.</span>Choose a time</h2>
          <p data-booking-target="slotsHint" class="text-warm-gray-600">Select a service above to see open times.</p>
          <div data-booking-target="slots" class="mt-2 flex flex-wrap gap-2"></div>
        </section>

        <!-- Step 4: Details -->
        <section class="rounded-3xl bg-white p-6 sm:p-8 shadow-warm border border-cream-200">
          <h2 class="font-serif text-xl text-warm-gray-800 mb-4"><span class="text-terracotta-500 mr-2">4.</span>Your details</h2>
          <form data-action="submit->booking#submit" data-booking-target="form" class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="booking-name" class="mb-1 block text-sm font-medium text-warm-gray-700">First name</label>
              <input id="booking-name" type="text" required data-booking-target="name" autocomplete="given-name"
                     class="w-full rounded-xl border border-cream-200 px-3 py-2.5">
            </div>
            <div>
              <label for="booking-phone" class="mb-1 block text-sm font-medium text-warm-gray-700">Mobile number</label>
              <input id="booking-phone" type="tel" required data-booking-target="phone" autocomplete="tel" placeholder="(704) 555-1234"
                     class="w-full rounded-xl border border-cream-200 px-3 py-2.5">
            </div>
            <div class="sm:col-span-2">
              <label for="booking-email" class="mb-1 block text-sm font-medium text-warm-gray-700">Email <span class="text-warm-gray-500">(optional, for confirmations)</span></label>
              <input id="booking-email" type="email" data-booking-target="email" autocomplete="email"
                     class="w-full rounded-xl border border-cream-200 px-3 py-2.5">
            </div>
            <div class="sm:col-span-2">
              <label for="booking-note" class="mb-1 block text-sm font-medium text-warm-gray-700">Anything we should know? <span class="text-warm-gray-500">(optional)</span></label>
              <textarea id="booking-note" rows="2" data-booking-target="note"
                        class="w-full rounded-xl border border-cream-200 px-3 py-2.5"></textarea>
            </div>
            <div class="sm:col-span-2 flex flex-col gap-3">
              <p data-booking-target="summary" class="text-warm-gray-600"></p>
              <p data-booking-target="error" class="hidden text-terracotta-600"></p>
              <button type="submit" data-booking-target="submitBtn" disabled
                      class="inline-flex items-center justify-center rounded-full bg-terracotta-500 px-8 py-4 font-medium text-cream-50 shadow-warm transition-all duration-300 hover:bg-terracotta-600 disabled:cursor-not-allowed disabled:opacity-40">
                Confirm booking
              </button>
            </div>
          </form>
        </section>

        <!-- Confirmation -->
        <section data-booking-target="confirmation" class="hidden rounded-3xl border border-sage-200 bg-white p-8 text-center shadow-warm">
          <h2 class="font-serif text-2xl text-warm-gray-800">You're booked! 💅</h2>
          <p data-booking-target="confirmationDetails" class="mt-3 text-warm-gray-700"></p>
          <p class="mt-2 text-warm-gray-600">We've saved your appointment — you'll get a reminder before your visit. See you soon!</p>
          <a href="/" class="mt-6 inline-block font-medium text-terracotta-600 underline underline-offset-4">Back to the site</a>
        </section>
      </div>
    <% end %>

    <p class="mt-10 text-center text-warm-gray-600">
      Prefer to talk? Call us at
      <a href="tel:<%= salon.phone %>" class="font-medium text-terracotta-600 underline underline-offset-4"><%= salon.phone_display %></a>.
    </p>
  </div>
</main>

<%= render "shared/footer" %>
