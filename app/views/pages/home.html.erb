          <div class="mt-8 md:mt-10 flex flex-col sm:flex-row items-center gap-4 opacity-0 animate-fade-in-up animation-delay-400"> <a href="tel:+17048249032" class="inline-flex items-center justify-center px-8 py-4 bg-sage-500 text-white font-medium rounded-full transition-all duration-300 hover:bg-sage-600 hover:shadow-lg hover:shadow-sage-500/30"> Book Appointment </a> <a href="#services" class="text-[#666] hover:text-sage-600 transition-colors underline underline-offset-4 decoration-sage-300 hover:decoration-sage-500"> View Services </a> </div>
        </div>
      </div>
      <!-- Right decorative branch (mirrored) -->
      <div class="hidden lg:block absolute right-0 top-1/3 w-32 opacity-20 transform scale-x-[-1]"> <%= icon 'branch', classes: 'text-[#444]' %> </div>
    </div>
  </div>
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in animation-delay-600"> <a href="#about" class="flex flex-col items-center text-[#666] hover:text-sage-600 transition-colors"> <span class="text-xs tracking-widest uppercase mb-2">Scroll</span> <%= icon 'chevron-down', classes: 'w-5 h-5 animate-bounce' %> </a> </div>
