<%= render 'shared/navigation' %>
<!-- ===== HERO SECTION ===== -->
<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden marble-texture"> <!-- Background subtle veining -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gradient-to-br from-[#e0e0e0]/40 to-transparent rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/3 right-1/4 w-80 h-80 bg-gradient-to-tl from-[#e0e0e0]/30 to-transparent rounded-full blur-3xl"></div>
    </div>
  </div>
  <!-- Hero Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-0">
    <div class="flex flex-col items-center justify-center"> <!-- Left decorative branch -->
      <div class="hidden lg:block absolute left-0 top-1/3 w-32 opacity-20"> <%= icon 'branch', classes: 'text-[#444]' %> </div>
      <!-- Main Hero Image Container -->
      <div class="relative w-full max-w-lg lg:max-w-xl xl:max-w-2xl mx-auto"> <!-- White glow -->
        <div class="absolute inset-0 hero-glow scale-110"></div>
        <!-- Hero Image Placeholder -->
        <div class="relative aspect-[3/4] rounded-full overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-[#f5f5f5] via-white to-[#fafafa] flex items-center justify-center">
            <div class="text-center px-8">
              <div class="w-48 h-48 mx-auto mb-6 rounded-full bg-gradient-to-br from-sage-100 to-[#eee] flex items-center justify-center"> <%= icon 'hand-raised', classes: 'w-24 h-24 text-sage-400' %> </div>
              <p class="text-sage-400 text-sm font-light tracking-wider">Hero Image</p>
              <p class="text-sage-300 text-xs mt-1">Replace with elegant hands photo</p>
            </div>
          </div>
        </div>
        <!-- Overlay Text -->
        <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6 pt-16">
          <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-[#444] tracking-wide leading-tight text-shadow-soft opacity-0 animate-fade-in-down"> Full-Service<br>
            <span class="italic font-light">Nail Salon & Spa</span> </h1>
