        <div class="bg-[#fafafa] rounded-2xl p-6 text-center border border-[#eee]"> <%= icon 'map-pin', classes: 'w-10 h-10 text-sage-600 mx-auto mb-2' %>
          <div class="text-[#666] text-sm">Market St, Cramerton</div>
