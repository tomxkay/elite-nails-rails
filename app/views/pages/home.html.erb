          <div class="text-[#666] text-sm">Expert Technicians</div>
        </div>
        <div class="bg-[#fafafa] rounded-2xl p-6 text-center border border-[#eee]">
          <div class="font-serif text-4xl text-sage-600 mb-2">★</div>
          <div class="text-[#666] text-sm">5-Star Reviews</div>
