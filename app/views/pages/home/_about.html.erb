<!-- ===== ABOUT SECTION ===== -->
<section id="about" class="relative py-24 lg:py-32 warm-gradient-cream overflow-hidden"
         data-controller="parallax"
         data-parallax-direction-value="up"
         data-parallax-speed-value="2.4"
         data-parallax-start-value="top bottom"
         data-parallax-end-value="top top">
  <div class="absolute inset-0 pointer-events-none opacity-40" aria-hidden="true">
    <div class="absolute -top-40 -left-20 w-96 h-96 rounded-full bg-peach-100 blur-3xl"></div>
    <div class="absolute -bottom-40 -right-10 w-[28rem] h-[28rem] rounded-full bg-sage-100 blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div data-controller="scroll-reveal" data-scroll-reveal-animation-value="fadeInUp">
        <%= render 'shared/section_header',
                   eyebrow: 'Welcome to Elite Nails',
                   title: 'Your Neighborhood',
                   title_accent: 'Nail Sanctuary',
                   align: :left %>

        <div class="mt-6 space-y-4 text-warm-gray-700 leading-relaxed">
          <p>
            Since 2003, Elite Nails has been a beloved fixture on Market Street in downtown Cramerton. Our cozy salon offers a welcoming escape from the everyday, where skilled technicians transform your nails into works of art.
          </p>
          <p>
            Whether you're seeking a classic manicure, a luxurious spa pedicure, or the latest in gel and acrylic designs, our dedicated team brings precision, creativity, and genuine care to every service.
          </p>
        </div>

        <div class="mt-8">
          <%= render 'shared/cta_button',
                     text: 'Schedule Your Visit',
                     href: 'tel:+17048249032',
                     style: :solid,
                     size: :md %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-6" data-controller="stagger" data-stagger-amount-value="0.15" data-stagger-from-value="scale">
        <% stats = [
          { value: '20+', label: 'Years of Excellence' },
          { value: '3+', label: 'Expert Technicians' },
          { value: '★', label: '5-Star Reviews' },
          { icon_name: 'map-pin', label: 'Market St, Cramerton' }
        ] %>

        <% stats.each do |stat| %>
          <%= render 'shared/stat_card', **stat %>
        <% end %>
      </div>
    </div>
  </div>
</section>
