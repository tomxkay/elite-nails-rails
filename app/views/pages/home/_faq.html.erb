<!-- ===== FAQ SECTION ===== -->
<%#
  Frequently asked questions. The `faqs` array is the single source of truth for
  both the visible accordion and the FAQPage JSON-LD below it, so they never
  drift. Questions/answers are written with local keywords (Cramerton, Belmont,
  Gaston County + service names) to match long-tail "near me" searches.
  Answers are plain text so they can be reused verbatim in structured data.
%>
<%
  faqs = [
    {
      question: "Where is Elite Nails located?",
      answer: "Elite Nails is at #{salon.street}, #{salon.city}, #{salon.region} #{salon.postal_code}, on Market Street in downtown Cramerton. We proudly serve Cramerton, Belmont, Mount Holly, and the greater Gaston County area."
    },
    {
      # Phone-first, matching the rest of the site. The old answer promised that
      # booking ahead "guarantees your preferred time and technician" — online
      # booking cannot do that, since only one technician takes /book
      # appointments. See docs/booking-adoption-notes.md.
      question: "Do I need an appointment, or do you take walk-ins?",
      answer: "Both! Most of our guests call ahead at #{salon.phone_display}, and that's still the surest way to get the time and technician you'd like. Select services can also be booked online. Walk-ins are always welcome based on availability."
    },
    {
      # Lists real menu categories only. This previously advertised "spa
      # treatments", which has never been on the menu — the same wording that
      # produced the phantom "Spa Pedicure". Waxing is real and was missing.
      question: "What nail services do you offer in Cramerton?",
      answer: "We offer manicures and pedicures, gel and dip powder nails, acrylic full sets and fills, custom nail art, and waxing — all in a clean, family-owned salon that's been serving Cramerton since 2003."
    },
    {
      question: "Do you do gel and dip powder nails?",
      answer: "Yes. Gel manicures and dip powder are two of our most popular services, along with acrylics and classic polish. Our technicians can help you choose the best option for your nails and lifestyle."
    },
    {
      question: "How do I book an appointment at Elite Nails?",
      answer: "Give us a call at #{salon.phone_display} and we'll find a time that works for you — that's how most appointments are made, and it's the only way to request a particular technician. You can also book select services online using the booking button on this page."
    },
    {
      question: "How do I redeem a promotion or special offer?",
      # Deliberately names no specific offer: promotions change, and this answer
      # is duplicated into the FAQPage JSON-LD, so a stale one would drift in two
      # places at once. The specials section is the source of truth for what's
      # currently running.
      answer: "Just let us know! There are no codes or coupons to bring — simply mention the offer when you arrive and we'll take care of it at the counter."
    },
    {
      # "Hospital-grade disinfectant" is a specific regulatory claim about a
      # product class, not a figure of speech — dropped in favour of describing
      # what actually happens between guests, which needs no verification.
      question: "Is Elite Nails clean and hygienic?",
      answer: "Absolutely. Tools and stations are disinfected between guests, and every pedicure gets a fresh liner and a sanitized bowl. Cleanliness is a point of pride for the family, and it's something guests mention often in our reviews."
    }
  ]
%>

<section id="faq" class="py-24 lg:py-32 bg-cream-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/section_header',
               eyebrow: 'Good to Know',
               title: 'Frequently Asked',
               title_accent: 'Questions',
               subtitle: 'Everything you need to know before your visit to our Cramerton nail salon.' %>

    <div class="mt-12 space-y-4"
         data-controller="scroll-reveal"
         data-scroll-reveal-animation-value="fadeInUp">
      <% faqs.each do |faq| %>
        <details class="group rounded-2xl border border-cream-200 bg-white/80 shadow-warm-sm backdrop-blur transition-colors open:border-terracotta-200">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5 list-none">
            <h3 class="font-serif text-lg text-warm-gray-900"><%= faq[:question] %></h3>
            <%= icon 'chevron-down', classes: 'w-5 h-5 shrink-0 text-terracotta-600 transition-transform group-open:rotate-180' %>
          </summary>
          <%# linkify_phone adds the tel: anchor for display only — the answer
              stays plain text so the JSON-LD below carries no markup. %>
          <p class="px-6 pb-6 -mt-1 text-warm-gray-700 font-light leading-relaxed">
            <%= linkify_phone(faq[:answer]) %>
          </p>
        </details>
      <% end %>
    </div>
  </div>

  <%# FAQPage structured data — built from the same `faqs` array so it always
      matches the visible content (a Google requirement for FAQ markup). %>
  <% faq_ld = {
       "@context" => "https://schema.org",
       "@type" => "FAQPage",
       "mainEntity" => faqs.map do |faq|
         {
           "@type" => "Question",
           "name" => faq[:question],
           "acceptedAnswer" => { "@type" => "Answer", "text" => faq[:answer] }
         }
       end
     } %>
  <script type="application/ld+json"><%= raw faq_ld.to_json %></script>
</section>
