<!-- ===== HERO SECTION ===== -->
<section id="home"
         class="relative overflow-hidden bg-cream-50 min-h-screen"
         data-controller="hero quick-availability"
         data-action="keydown@window->quick-availability#keydown"
         data-quick-availability-options-url-value="<%= book_path %>/availability/options"
         data-quick-availability-next-url-value="<%= book_path %>/availability/next"
         data-quick-availability-booking-url-value="<%= book_path %>"
         data-quick-availability-fallback-url-value="<%= booking_link %>">
  <div class="absolute inset-0 hero-ambient"></div>
  <div class="absolute inset-0 hero-grid-lines pointer-events-none"></div>
  <div class="absolute left-4 top-4 h-72 w-72 rounded-full hero-orb-terra blur-3xl"></div>
  <div class="absolute right-6 top-10 h-80 w-80 rounded-full hero-orb-sage blur-3xl"></div>
  <%= image_tag "nail-polish-drip-gold.webp",
                alt: "",
                class: "hero-polish-drip",
                width: 458,
                height: 240,
                loading: "lazy",
                decoding: "async",
                aria: { hidden: true } %>
  <%= image_tag "hero-model-right.webp",
                alt: "",
                class: "hero-model-right",
                width: 1400,
                height: 911,
                decoding: "async",
                aria: { hidden: true } %>

  <div class="hero-with-promo-offset relative z-20 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-10 grid lg:grid-cols-[1.05fr_0.95fr] items-center gap-14">
    <div class="hero-copy space-y-8">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-terracotta-200/60 bg-white/80 backdrop-blur text-terracotta-700 uppercase tracking-[0.22em] text-[0.7rem] font-semibold shadow-warm-sm" data-hero-target="cta">
        <span class="h-2 w-2 rounded-full bg-terracotta-500 shadow-warm-sm"></span>
        Cramerton's neighborhood nail salon since 2003
      </div>

      <div class="space-y-4">
        <p class="text-sm uppercase tracking-[0.32em] text-terracotta-600/80 font-semibold">Come as you are</p>
        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl text-warm-gray-900 leading-[0.98] tracking-tight" data-hero-target="heading">
          Beautiful nails.
          <span class="block text-warm-gray-700 font-normal">A warm welcome.</span>
        </h1>
      </div>

      <p class="text-lg md:text-xl text-warm-gray-700 leading-relaxed max-w-2xl" data-hero-target="subtitle">
        Manicures, pedicures, gel, dip, and nail art from a friendly local team. Walk-ins always welcome.
      </p>

      <div class="flex flex-col sm:flex-row gap-4" data-hero-target="cta">
        <%= render 'shared/cta_button',
                    text: 'Book An Appointment',
                    href: booking_link,
                    style: :solid,
                    size: :lg,
                    icon: 'calendar-days',
                    classes: 'shadow-warm-lg text-base px-6 py-3 bg-terracotta-700 hover:bg-terracotta-800' %>
        <%= render 'shared/cta_button',
                    text: 'View The Menu',
                    href: '#services',
                    style: :light,
                    size: :lg,
                    icon: 'sparkles',
                    classes: 'text-base px-6 py-3 border border-warm-gray-200/80 bg-white/70 backdrop-blur text-warm-gray-800 hover:text-terracotta-700 hover:border-terracotta-200 shadow-warm-sm' %>
      </div>

      <%# Calling is the salon's primary channel, so it's offered right at the
          top rather than only in the contact section. Kept as a text link so it
          doesn't crowd the two-button hero. %>
      <p class="hidden flex-wrap items-center gap-2 text-warm-gray-700 sm:flex">
        <%= icon 'phone', classes: 'h-4 w-4 text-terracotta-500', 'aria-hidden': true %>
        <span>Prefer to call?</span>
        <a href="tel:<%= salon.phone %>" class="font-medium text-terracotta-600 underline underline-offset-4 decoration-terracotta-300 transition-colors hover:text-terracotta-700"><%= salon.phone_display %></a>
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 max-w-3xl">
        <%# Every claim here must be verifiable. These three replaced copy that
            wasn't: "200+ hues" (never counted), "breathable polishes" (a real
            product category the salon doesn't stock — a false product claim,
            not vague puffery), and "private seating" (there is none on the
            floor; the private room is for waxing only). If you add a card,
            confirm it with the owner first. %>
        <div class="rounded-2xl border border-warm-gray-200/80 bg-white/80 backdrop-blur px-5 py-6 shadow-warm-md">
          <p class="text-xs uppercase tracking-[0.18em] text-warm-gray-500">Family-Owned</p>
          <p class="font-serif text-3xl text-warm-gray-900 mt-2">Since 2003</p>
          <p class="text-sm text-warm-gray-600">Same family, same Market Street shop.</p>
        </div>
        <div class="rounded-2xl border border-warm-gray-200/80 bg-white/80 backdrop-blur px-5 py-6 shadow-warm-md">
          <p class="text-xs uppercase tracking-[0.18em] text-warm-gray-500">By Appointment</p>
          <p class="font-serif text-3xl text-warm-gray-900 mt-2">Call ahead</p>
          <p class="text-sm text-warm-gray-600">We'll have your seat ready — walk-ins welcome too.</p>
        </div>
        <div class="rounded-2xl border border-warm-gray-200/80 bg-white/80 backdrop-blur px-5 py-6 shadow-warm-md">
          <p class="text-xs uppercase tracking-[0.18em] text-warm-gray-500">Private Waxing Room</p>
          <p class="font-serif text-3xl text-warm-gray-900 mt-2">Brow, lip &amp; chin</p>
          <p class="text-sm text-warm-gray-600">A quiet, private space for waxing services.</p>
        </div>
      </div>
    </div>

    <div class="hero-availability-wrap relative z-30 flex items-end justify-start">
      <button type="button"
              class="hero-availability-card hero-availability-pulse relative z-40 block w-full max-w-sm mx-auto text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-terracotta-500 focus-visible:ring-offset-2 md:w-[280px] lg:mx-0"
              data-hero-target="cta availability"
              data-quick-availability-target="trigger"
              data-action="click->quick-availability#open"
              aria-controls="quickAvailabilityDialog"
              aria-haspopup="dialog"
              aria-expanded="false">
        <span class="hero-availability-card-inner glass-warm block rounded-2xl px-5 py-4 text-left shadow-warm-lg">
          <p class="text-xs uppercase tracking-[0.18em] text-terracotta-700">Check availability</p>
          <span class="mt-2 flex items-center justify-between text-warm-gray-900">
            <span>
              <span class="font-serif text-2xl leading-tight block">Find your next opening</span>
              <span class="text-sm text-warm-gray-600 block">See times by technician</span>
            </span>
            <span class="h-12 w-12 rounded-full bg-terracotta-700 text-cream-50 flex items-center justify-center shadow-warm-md">
              <%= icon 'calendar-days', classes: 'w-5 h-5' %>
            </span>
          </span>
        </span>
      </button>
    </div>
  </div>

  <%= render "shared/quick_availability_dialog" %>

  <div class="hidden relative mt-8 pb-4 justify-center z-20 lg:absolute lg:bottom-8 lg:left-0 lg:right-0 lg:mt-0 lg:pb-0 lg:flex" data-hero-target="scroll">
    <a href="#about" class="flex items-center gap-3 text-warm-gray-700 hover:text-terracotta-700 transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll">
      <span class="h-11 w-11 rounded-full border border-warm-gray-200/80 bg-white/70 backdrop-blur flex items-center justify-center shadow-warm-sm">
        <%= icon 'chevron-down', classes: 'w-5 h-5' %>
      </span>
      <span class="text-xs uppercase tracking-[0.26em]">Scroll to explore</span>
    </a>
  </div>

</section>
