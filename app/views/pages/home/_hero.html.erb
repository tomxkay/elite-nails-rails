<!-- ===== HERO SECTION ===== -->
<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-cream-100" data-controller="hero">
  <!-- Full-screen background image -->
  <div class="absolute inset-0">
    <%= image_tag "hero.png",
                  alt: "Elite Nails Salon",
                  class: "w-full h-full object-cover brightness-[0.9]",
                  loading: "eager" %>

    <!-- Warm gradient overlays for text visibility -->
    <div class="absolute inset-0 hero-gradient-overlay"></div>
    <div class="absolute inset-0 hero-warm-filter"></div>
    <div class="hero-warm-vignette"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28">
    <div class="flex flex-col items-center lg:items-start justify-center text-center lg:text-left gap-8">
      <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full glass-warm text-terracotta-700 uppercase tracking-[0.25em] text-xs font-semibold" data-hero-target="cta">
        <span class="w-2 h-2 rounded-full bg-terracotta-500"></span>
        Warm & Welcoming Since 2003
      </div>

      <!-- Headline -->
      <h1 class="font-serif text-6xl sm:text-7xl md:text-8xl lg:text-9xl text-white font-semibold leading-[0.95] text-shadow-soft drop-shadow-xl" data-hero-target="heading">
        Luxury Nail Care
        <span class="block text-cream-100 font-light italic">With Heart & Artistry</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-cream-50 text-lg md:text-xl lg:text-2xl font-light tracking-wide max-w-3xl text-shadow-soft" data-hero-target="subtitle">
        Full-service manicures, pedicures, and nail artistry in downtown Cramerton. Step into warmth, leave feeling polished.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center lg:items-start gap-4" data-hero-target="cta">
        <%= render 'shared/cta_button',
                    text: 'Book Appointment',
                    href: booking_link,
                    style: :solid,
                    size: :lg,
                    icon: 'calendar-days',
                    classes: 'shadow-warm-xl' %>
        <%= render 'shared/cta_button',
                    text: 'View Services',
                    href: '#services',
                    style: :light,
                    size: :lg,
                    icon: 'sparkles',
                    classes: 'bg-white/20 backdrop-blur text-cream-50 border border-cream-200/60 hover:bg-cream-50 hover:text-terracotta-600' %>
      </div>

      <div class="flex flex-wrap items-center gap-3 text-sm uppercase tracking-[0.15em] text-cream-100/80">
        <span class="px-3 py-1 rounded-full bg-white/10 border border-white/30">Family-Owned</span>
        <span class="px-3 py-1 rounded-full bg-white/10 border border-white/30">Luxury Pedicures</span>
        <span class="px-3 py-1 rounded-full bg-white/10 border border-white/30">Nail Artistry</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-0 right-0 flex justify-center animate-bounce" data-hero-target="scroll">
    <a href="#about" class="flex flex-col items-center text-white/80 hover:text-white transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll">
      <span class="text-xs tracking-widest uppercase mb-2">Scroll to Explore</span>
      <%= icon 'chevron-down', classes: 'w-5 h-5' %>
    </a>
  </div>
</section>
