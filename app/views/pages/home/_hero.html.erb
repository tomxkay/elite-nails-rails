<!-- ===== HERO SECTION ===== -->
<section id="home"
         class="relative overflow-hidden bg-cream-50 min-h-screen"
         data-controller="hero">
  <div class="absolute inset-0 hero-ambient"></div>
  <div class="absolute inset-0 hero-grid-lines pointer-events-none"></div>
  <div class="absolute left-4 top-4 h-72 w-72 rounded-full hero-orb-terra blur-3xl"></div>
  <div class="absolute right-6 top-10 h-80 w-80 rounded-full hero-orb-sage blur-3xl"></div>

  <div class="hero-with-promo-offset relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-10 grid lg:grid-cols-[1.05fr_0.95fr] items-center gap-14">
    <div class="space-y-8">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-terracotta-200/60 bg-white/80 backdrop-blur text-terracotta-700 uppercase tracking-[0.22em] text-[0.7rem] font-semibold shadow-warm-sm" data-hero-target="cta">
        <span class="h-2 w-2 rounded-full bg-terracotta-500 shadow-warm-sm"></span>
        Cramerton's neighborhood nail salon since 2003
      </div>

      <div class="space-y-4">
        <p class="text-sm uppercase tracking-[0.32em] text-terracotta-600/80 font-semibold">Come as you are</p>
        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl text-warm-gray-900 leading-[0.98] tracking-tight" data-hero-target="heading">
          Beautiful nails.
          <span class="block text-warm-gray-700 font-normal">A warm welcome.</span>
        </h1>
      </div>

      <p class="text-lg md:text-xl text-warm-gray-700 leading-relaxed max-w-2xl" data-hero-target="subtitle">
        Manicures, pedicures, gel, dip, and nail art from a friendly local team that takes care of the details.
      </p>

      <div class="flex flex-col sm:flex-row gap-4" data-hero-target="cta">
        <%= render 'shared/cta_button',
                    text: 'Book An Appointment',
                    href: booking_link,
                    style: :solid,
                    size: :lg,
                    icon: 'calendar-days',
                    classes: 'shadow-warm-lg text-base px-6 py-3 bg-terracotta-700 hover:bg-terracotta-800' %>
        <%= render 'shared/cta_button',
                    text: 'View The Menu',
                    href: '#services',
                    style: :light,
                    size: :lg,
                    icon: 'sparkles',
                    classes: 'text-base px-6 py-3 border border-warm-gray-200/80 bg-white/70 backdrop-blur text-warm-gray-800 hover:text-terracotta-700 hover:border-terracotta-200 shadow-warm-sm' %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 max-w-3xl">
        <div class="rounded-2xl border border-warm-gray-200/80 bg-white/80 backdrop-blur px-5 py-6 shadow-warm-md">
          <p class="text-xs uppercase tracking-[0.18em] text-warm-gray-500">Signature Finishes</p>
          <p class="font-serif text-3xl text-warm-gray-900 mt-2">200+ hues</p>
          <p class="text-sm text-warm-gray-600">Gel, dip, and custom art curated seasonally.</p>
        </div>
        <div class="rounded-2xl border border-warm-gray-200/80 bg-white/80 backdrop-blur px-5 py-6 shadow-warm-md">
          <p class="text-xs uppercase tracking-[0.18em] text-warm-gray-500">Wellness First</p>
          <p class="font-serif text-3xl text-warm-gray-900 mt-2">Clean formulas</p>
          <p class="text-sm text-warm-gray-600">Breathable polishes, gentle scrubs, mindful aromas.</p>
        </div>
        <div class="rounded-2xl border border-warm-gray-200/80 bg-white/80 backdrop-blur px-5 py-6 shadow-warm-md">
          <p class="text-xs uppercase tracking-[0.18em] text-warm-gray-500">By Appointment</p>
          <p class="font-serif text-3xl text-warm-gray-900 mt-2">Zero rush</p>
          <p class="text-sm text-warm-gray-600">Private seating and attentive, unhurried service.</p>
        </div>
      </div>
    </div>

    <div class="relative" data-hero-target="image">
      <div class="absolute right-4 top-4 px-4 py-2 rounded-full border border-terracotta-200/80 bg-white/85 backdrop-blur shadow-warm-sm hidden sm:flex items-center gap-2 text-terracotta-700 uppercase tracking-[0.22em] text-[0.7rem] z-20">
        <span class="h-1.5 w-1.5 rounded-full bg-terracotta-500 shadow-warm-sm"></span>
        est. 2003
      </div>
      <div class="relative overflow-hidden rounded-[28px] shadow-[0_30px_80px_-40px_rgba(104,72,57,0.6)] ring-1 ring-cream-200 bg-warm-gray-900/5">
        <%= image_tag "hero-768.webp",
                      alt: "Elite Nails Salon interior",
                      class: "w-full h-full object-cover brightness-95 contrast-105",
                      loading: "eager",
                      fetchpriority: "high",
                      decoding: "async",
                      width: 1536,
                      height: 1024,
                      srcset: "#{asset_path('hero-768.webp')} 768w, #{asset_path('hero-1536.webp')} 1536w",
                      sizes: "(min-width: 1024px) 45vw, 100vw" %>
        <div class="absolute inset-0 hero-photo-overlay pointer-events-none"></div>
      </div>

      <div class="absolute -bottom-10 left-10 w-[280px] glass-warm rounded-2xl px-5 py-4 shadow-warm-lg" data-hero-target="cta">
        <p class="text-xs uppercase tracking-[0.18em] text-terracotta-700 mb-2">Next availability</p>
        <div class="flex items-center justify-between text-warm-gray-900">
          <div>
            <p class="font-serif text-2xl leading-tight">This Week</p>
            <p class="text-sm text-warm-gray-600">Reserve by phone or online</p>
          </div>
          <div class="h-12 w-12 rounded-full bg-terracotta-700 text-cream-50 flex items-center justify-center shadow-warm-md">
            <%= icon 'phone', classes: 'w-5 h-5' %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-0 right-0 flex justify-center z-20" data-hero-target="scroll">
    <a href="#about" class="flex items-center gap-3 text-warm-gray-700 hover:text-terracotta-700 transition-colors" data-controller="smooth-scroll" data-action="click->smooth-scroll#scroll">
      <span class="h-11 w-11 rounded-full border border-warm-gray-200/80 bg-white/70 backdrop-blur flex items-center justify-center shadow-warm-sm">
        <%= icon 'chevron-down', classes: 'w-5 h-5' %>
      </span>
      <span class="text-xs uppercase tracking-[0.26em]">Scroll to explore</span>
    </a>
  </div>

  <div class="pointer-events-none hidden md:block absolute bottom-0 right-20 translate-y-[12%] translate-x-[8%] z-10" aria-hidden="true" data-hero-target="hand">
    <div class="relative">
      <div class="absolute -top-6 -left-6 h-24 w-24 rounded-full hero-orb-terra blur-3xl opacity-70"></div>
      <%= image_tag "nails-hand.webp",
                    alt: "Polished hand with manicure",
                    class: "relative max-w-none object-contain drop-shadow-[0_25px_80px_-40px_rgba(104,72,57,0.55)]",
                    loading: "lazy",
                    decoding: "async" %>
    </div>
  </div>
</section>
