<!-- ===== HERO SECTION ===== -->
<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden marble-texture">
  <div class="absolute inset-0">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gradient-to-br from-[#e0e0e0]/40 to-transparent rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/3 right-1/4 w-80 h-80 bg-gradient-to-tl from-[#e0e0e0]/30 to-transparent rounded-full blur-3xl"></div>
    </div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-0">
    <div class="flex flex-col items-center justify-center">
      <div class="hidden lg:block absolute left-0 top-1/3 w-32 opacity-20">
        <%= icon 'branch', classes: 'text-[#444]' %>
      </div>

      <div class="relative w-full max-w-lg lg:max-w-xl xl:max-w-2xl mx-auto">
        <div class="absolute inset-0 hero-glow scale-110"></div>
        <div class="relative aspect-[3/4] rounded-full overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-[#f5f5f5] via-white to-[#fafafa] flex items-center justify-center">
            <div class="text-center px-8">
              <div class="w-48 h-48 mx-auto mb-6 rounded-full bg-gradient-to-br from-sage-100 to-[#eee] flex items-center justify-center">
                <%= icon 'hand-raised', classes: 'w-24 h-24 text-sage-400' %>
              </div>
              <p class="text-sage-400 text-sm font-light tracking-wider">Hero Image</p>
              <p class="text-sage-300 text-xs mt-1">Replace with elegant hands photo</p>
            </div>
          </div>
        </div>

        <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6 pt-16">
          <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-[#444] tracking-wide leading-tight text-shadow-soft opacity-0 animate-fade-in-down">
            Full-Service<br>
            <span class="italic font-light">Nail Salon & Spa</span>
          </h1>
          <p class="mt-4 md:mt-6 text-[#666] text-base md:text-lg font-light tracking-wide max-w-md text-shadow-soft opacity-0 animate-fade-in-up animation-delay-200">
            Luxury manicures & pedicures in the heart of Cramerton, NC
          </p>
          <div class="mt-8 md:mt-10 flex flex-col sm:flex-row items-center gap-4 opacity-0 animate-fade-in-up animation-delay-400">
            <%= render 'shared/cta_button',
                        text: 'Book Appointment',
                        href: 'tel:+17048249032',
                        style: :solid,
                        size: :lg %>
            <%= render 'shared/cta_button',
                        text: 'View Services',
                        href: '#services',
                        style: :ghost,
                        size: :md %>
          </div>
        </div>
      </div>

      <div class="hidden lg:block absolute right-0 top-1/3 w-32 opacity-20 transform scale-x-[-1]">
        <%= icon 'branch', classes: 'text-[#444]' %>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in animation-delay-600">
    <a href="#about" class="flex flex-col items-center text-[#666] hover:text-sage-600 transition-colors">
      <span class="text-xs tracking-widest uppercase mb-2">Scroll</span>
      <%= icon 'chevron-down', classes: 'w-5 h-5 animate-bounce' %>
    </a>
  </div>
</section>
