<!-- ===== CTA BANNER ===== -->
<section class="py-20 warm-gradient-terracotta" data-controller="scroll-reveal" data-scroll-reveal-animation-value="fadeInUp">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-cream-50 mb-4 drop-shadow-lg">Ready to Be Pampered?</h2>
    <p class="text-cream-100 text-lg mb-8 max-w-2xl mx-auto">
      Book your appointment today and experience the Elite Nails difference. Walk-ins are always welcome!
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <%= render 'shared/cta_button',
                 text: 'Book Now',
                 href: booking_link,
                 style: :light,
                 size: :lg,
                 icon: 'calendar-days',
                 icon_classes: 'mr-1' %>
      <%= render 'shared/cta_button',
                 text: 'Get Directions',
                 href: 'https://maps.google.com/?q=202+Market+St+F,+Cramerton,+NC+28032',
                 target: '_blank',
                 rel: 'noopener',
                 style: :ghost,
                 size: :md,
                 icon: 'map-pin',
                 icon_classes: 'mr-1',
                 classes: 'text-white hover:text-sage-100 no-underline' %>
    </div>
  </div>
</section>
