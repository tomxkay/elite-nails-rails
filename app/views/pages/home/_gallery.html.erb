<!-- ===== GALLERY SECTION ===== -->
<section id="gallery" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/section_header',
               eyebrow: 'Our Work',
               title: 'Gallery',
               subtitle: 'A glimpse of our nail artistry and salon atmosphere' %>

    <div class="mt-16 grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6" data-controller="stagger" data-stagger-amount-value="0.12" data-stagger-from-value="scale">
      <% gallery_items = [
        { label: 'Manicure Art', seed: 'gallery-manicure-1' },
        { label: 'Nail Design', seed: 'gallery-nail-art-2' },
        { label: 'Spa Treatment', seed: 'gallery-spa-hands-3' },
        { label: 'Pedicure Service', seed: 'gallery-pedicure-4' },
        { label: 'Gel Nails', seed: 'gallery-gel-nails-5' },
        { label: 'French Manicure', seed: 'gallery-french-6' }
      ] %>

      <% gallery_items.each do |item| %>
        <%= render 'shared/gallery_item',
                   label: item[:label],
                   image_url: placeholder_image(width: 600, height: 600, seed: item[:seed]) %>
      <% end %>
    </div>

    <div class="mt-12 text-center">
      <a href="#" class="text-sage-600 hover:text-sage-700 font-medium inline-flex items-center gap-2 group">
        Follow us on Instagram for more
        <%= icon 'instagram', classes: 'w-5 h-5 transition-transform group-hover:translate-x-1' %>
      </a>
    </div>
  </div>
</section>
