<!-- ===== CONTACT SECTION ===== -->
<section id="contact" class="py-24 lg:py-32 warm-gradient-sage-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/section_header',
               eyebrow: 'Find Us',
               title: 'Visit Our Salon',
               subtitle: 'Located in the heart of downtown Cramerton on Market Street' %>

    <div class="mt-16 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <div data-controller="scroll-reveal" data-scroll-reveal-animation-value="fadeInLeft">
        <div class="card-surface-warm rounded-3xl p-8 md:p-10 shadow-warm-sm">
          <div class="flex items-start mb-8">
            <div class="w-12 h-12 rounded-xl bg-peach-100 flex items-center justify-center mr-4 flex-shrink-0 shadow-warm-sm">
              <%= icon 'map-pin', classes: 'w-6 h-6 text-terracotta-600' %>
            </div>
            <div>
              <h3 class="font-serif text-lg text-warm-gray-900 mb-1">Address</h3>
              <p class="text-warm-gray-700">
                202 Market St F<br>
                Cramerton, NC 28032
              </p>
              <a href="https://maps.google.com/?q=202+Market+St+F,+Cramerton,+NC+28032" target="_blank" class="mt-2 inline-block text-terracotta-600 hover:text-terracotta-700 text-sm font-medium">
                Get Directions →
              </a>
            </div>
          </div>

          <div class="flex items-start mb-8">
            <div class="w-12 h-12 rounded-xl bg-peach-100 flex items-center justify-center mr-4 flex-shrink-0 shadow-warm-sm">
              <%= icon 'phone', classes: 'w-6 h-6 text-terracotta-600' %>
            </div>
            <div>
              <h3 class="font-serif text-lg text-warm-gray-900 mb-1">Phone</h3>
              <a href="tel:+17048249032" class="text-terracotta-600 hover:text-terracotta-700 text-xl font-medium">
                (704) 824-9032
              </a>
              <p class="text-warm-gray-700 text-sm mt-1">Walk-ins welcome!</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-12 h-12 rounded-xl bg-peach-100 flex items-center justify-center mr-4 flex-shrink-0 shadow-warm-sm">
              <%= icon 'clock', classes: 'w-6 h-6 text-terracotta-600' %>
            </div>
            <div class="flex-1">
              <h3 class="font-serif text-lg text-warm-gray-900 mb-3">Hours</h3>
              <div class="space-y-2">
                <div class="flex justify-between py-2 border-b border-cream-200">
                  <span class="text-warm-gray-900">Monday – Friday</span>
                  <span class="text-warm-gray-700">10:00 AM – 7:00 PM</span>
                </div>
                <div class="flex justify-between py-2 border-b border-cream-200">
                  <span class="text-warm-gray-900">Saturday</span>
                  <span class="text-warm-gray-700">9:00 AM – 6:00 PM</span>
                </div>
                <div class="flex justify-between py-2">
                  <span class="text-warm-gray-900">Sunday</span>
                  <span class="text-terracotta-600 font-semibold">Closed</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div data-controller="scroll-reveal" data-scroll-reveal-animation-value="fadeInRight" data-scroll-reveal-delay-value="0.2">
        <div class="relative h-full min-h-[420px] overflow-hidden rounded-3xl ring-1 ring-cream-200 shadow-warm-sm">
          <iframe title="Map to Elite Nails, 202 Market St F, Cramerton, NC"
                  src="<%= salon_map_embed_url %>"
                  class="absolute inset-0 h-full w-full"
                  style="border:0;"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  allowfullscreen></iframe>
          <div class="pointer-events-none absolute bottom-4 left-4 right-4 flex justify-end">
            <%= render 'shared/cta_button',
                       text: 'Open in Google Maps',
                       href: 'https://maps.google.com/?q=202+Market+St+F,+Cramerton,+NC+28032',
                       target: '_blank',
                       rel: 'noopener',
                       style: :light,
                       size: :sm,
                       icon: 'map-pin',
                       classes: 'pointer-events-auto shadow-warm-lg' %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
