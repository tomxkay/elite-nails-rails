<!-- ===== CONTACT SECTION ===== -->
<section id="contact" class="py-24 lg:py-32 marble-texture">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/section_header',
               eyebrow: 'Find Us',
               title: 'Visit Our Salon',
               subtitle: 'Located in the heart of downtown Cramerton on Market Street' %>

    <div class="mt-16 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <div>
        <div class="bg-white rounded-3xl p-8 md:p-10 shadow-sm border border-[#eee]">
          <div class="flex items-start mb-8">
            <div class="w-12 h-12 rounded-xl bg-sage-50 flex items-center justify-center mr-4 flex-shrink-0">
              <%= icon 'map-pin', classes: 'w-6 h-6 text-sage-600' %>
            </div>
            <div>
              <h3 class="font-serif text-lg text-[#444] mb-1">Address</h3>
              <p class="text-[#666]">
                202 Market St F<br>
                Cramerton, NC 28032
              </p>
              <a href="https://maps.google.com/?q=202+Market+St+F,+Cramerton,+NC+28032" target="_blank" class="mt-2 inline-block text-sage-600 hover:text-sage-700 text-sm font-medium">
                Get Directions →
              </a>
            </div>
          </div>

          <div class="flex items-start mb-8">
            <div class="w-12 h-12 rounded-xl bg-sage-50 flex items-center justify-center mr-4 flex-shrink-0">
              <%= icon 'phone', classes: 'w-6 h-6 text-sage-600' %>
            </div>
            <div>
              <h3 class="font-serif text-lg text-[#444] mb-1">Phone</h3>
              <a href="tel:+17048249032" class="text-sage-600 hover:text-sage-700 text-xl font-medium">
                (704) 824-9032
              </a>
              <p class="text-[#666] text-sm mt-1">Walk-ins welcome!</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-12 h-12 rounded-xl bg-sage-50 flex items-center justify-center mr-4 flex-shrink-0">
              <%= icon 'clock', classes: 'w-6 h-6 text-sage-600' %>
            </div>
            <div class="flex-1">
              <h3 class="font-serif text-lg text-[#444] mb-3">Hours</h3>
              <div class="space-y-2">
                <div class="flex justify-between py-2 border-b border-[#f5f5f5]">
                  <span class="text-[#444]">Monday – Friday</span>
                  <span class="text-[#666]">10:00 AM – 7:00 PM</span>
                </div>
                <div class="flex justify-between py-2 border-b border-[#f5f5f5]">
                  <span class="text-[#444]">Saturday</span>
                  <span class="text-[#666]">9:00 AM – 6:00 PM</span>
                </div>
                <div class="flex justify-between py-2">
                  <span class="text-[#444]">Sunday</span>
                  <span class="text-sage-600 font-medium">Closed</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div>
        <div class="bg-[#f5f5f5] rounded-3xl h-full min-h-[400px] flex items-center justify-center border-2 border-dashed border-[#e0e0e0] overflow-hidden">
          <div class="text-center px-8">
            <%= icon 'map', classes: 'w-16 h-16 text-sage-300 mx-auto mb-4' %>
            <p class="text-sage-500 font-medium">Map Placeholder</p>
            <p class="text-sage-400 text-sm mt-2">202 Market St F, Cramerton, NC</p>
            <div class="mt-4 inline-flex">
              <%= render 'shared/cta_button',
                         text: 'Open in Google Maps',
                         href: 'https://maps.google.com/?q=202+Market+St+F,+Cramerton,+NC+28032',
                         target: '_blank',
                         rel: 'noopener',
                         style: :outline,
                         size: :md %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
