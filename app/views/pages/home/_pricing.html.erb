<!-- ===== PRICING SECTION ===== -->
<section id="pricing" class="relative overflow-hidden bg-cream-50 py-24 lg:py-28">
  <!-- ambient backdrop -->
  <div class="pointer-events-none absolute inset-0 hero-grid-lines opacity-30" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/section_header',
               eyebrow: 'Transparent Pricing',
               title: 'Pricing',
               subtitle: 'Clear, honest pricing — no surprises at the counter.' %>

    <p class="mt-6 flex flex-wrap items-center justify-center gap-2 text-center text-sm text-warm-gray-600">
      <%= icon "calendar-days", classes: "h-4 w-4 text-terracotta-400", "aria-hidden": true %>
      <span>Services marked with a calendar can be booked online — everything else is walk-in or by phone.</span>
    </p>

    <%# Content from the DB (PricingItem), grouped by category, with in-code
        DEFAULTS fallback. %>
    <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6" data-controller="stagger" data-stagger-amount-value="0.15" data-stagger-from-value="scale">
      <% PricingItem.grouped_for_display.each_with_index do |(category, items), i| %>
        <div class="card-surface-warm rounded-2xl p-7 shadow-warm-sm hover:shadow-warm-xl transition-shadow duration-300"
             data-controller="pricing-highlight"
             data-pricing-highlight-category-value="<%= category.downcase %>">
          <div class="flex items-baseline justify-between border-b border-cream-200 pb-4">
            <h3 class="font-serif text-2xl text-warm-gray-900"><%= category %></h3>
            <span class="font-serif text-lg text-terracotta-200" aria-hidden="true"><%= format("%02d", i + 1) %></span>
          </div>
          <%# Only `bookable` items link to /book. Short/add-on work (polish
              changes, repairs, trims, waxing) is walk-in, so those rows are
              plain text — linking them would promise a booking path that
              doesn't exist. %>
          <ul class="mt-2 divide-y divide-cream-200 text-sm text-warm-gray-700">
            <% items.each do |item| %>
              <li>
                <% if item.bookable %>
                  <a href="<%= book_path(service_name: item.name) %>"
                     class="group/row flex items-center justify-between gap-3 py-3 transition-colors hover:text-terracotta-700"
                     aria-label="Book <%= item.name %>">
                    <span class="flex min-w-0 items-center gap-2">
                      <span class="underline-offset-4 group-hover/row:underline"><%= item.name %></span>
                      <%= icon "calendar-days", classes: "h-3.5 w-3.5 shrink-0 text-terracotta-400", "aria-hidden": true %>
                    </span>
                    <span class="shrink-0 font-semibold text-terracotta-600"><%= item.price %></span>
                  </a>
                <% else %>
                  <div class="flex items-center justify-between gap-3 py-3">
                    <span class="min-w-0"><%= item.name %></span>
                    <span class="shrink-0 font-semibold text-terracotta-600"><%= item.price %></span>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-4 bg-peach-50 border border-cream-200 rounded-2xl px-6 py-5 shadow-warm-sm">
      <div>
        <p class="text-warm-gray-900 font-semibold">Questions or custom requests?</p>
        <p class="text-warm-gray-700 text-sm">Call us or book online — we’re happy to recommend the right service.</p>
      </div>
      <div class="flex items-center gap-3">
        <%= render 'shared/cta_button',
                   text: 'Book Online',
                   href: booking_link,
                   style: :solid,
                   size: :md,
                   icon: 'calendar-days' %>
        <%= render 'shared/cta_button',
                   text: 'Call the Salon',
                   href: 'tel:+17048249032',
                   style: :outline,
                   size: :sm,
                   icon: 'phone' %>
      </div>
    </div>
  </div>
</section>
