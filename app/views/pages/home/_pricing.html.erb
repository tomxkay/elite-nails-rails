<!-- ===== PRICING SECTION ===== -->
<section id="pricing" class="relative overflow-hidden bg-cream-50 py-24 lg:py-28">
  <!-- ambient backdrop -->
  <div class="pointer-events-none absolute inset-0 hero-grid-lines opacity-30" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/section_header',
               eyebrow: 'Transparent Pricing',
               title: 'Pricing',
               subtitle: 'Clear, honest pricing for hands, feet, and add-ons. Call for full menu and seasonal specials.' %>

    <% categories = [
      {
        title: "Hands",
        items: [
          ["Classic Manicure", "$20"],
          ["Gel Manicure", "$35"],
          ["Dip Powder", "$40"],
          ["French Add-On", "+$5"]
        ]
      },
      {
        title: "Feet",
        items: [
          ["Signature Pedicure", "$35"],
          ["Spa Pedicure", "$45"],
          ["Gel Pedicure", "$55"],
          ["Callus Care Upgrade", "+$8"]
        ]
      },
      {
        title: "Add-Ons",
        items: [
          ["Nail Art (per nail)", "$5+"],
          ["Acrylic Full Set", "$40+"],
          ["Acrylic Fill", "$30+"],
          ["Waxing (brows/lip/chin)", "$10+"]
        ]
      }
    ] %>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6" data-controller="stagger" data-stagger-amount-value="0.15" data-stagger-from-value="scale">
      <% categories.each_with_index do |category, i| %>
        <div class="card-surface-warm rounded-2xl p-7 shadow-warm-sm hover:shadow-warm-xl transition-shadow duration-300"
             data-controller="pricing-highlight"
             data-pricing-highlight-category-value="<%= category[:title].downcase %>">
          <div class="flex items-baseline justify-between border-b border-cream-200 pb-4">
            <h3 class="font-serif text-2xl text-warm-gray-900"><%= category[:title] %></h3>
            <span class="font-serif text-lg text-terracotta-200" aria-hidden="true"><%= format("%02d", i + 1) %></span>
          </div>
          <ul class="mt-2 divide-y divide-cream-200 text-sm text-warm-gray-700">
            <% category[:items].each do |name, price| %>
              <li class="flex justify-between py-3">
                <span><%= name %></span>
                <span class="text-terracotta-600 font-semibold"><%= price %></span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-4 bg-peach-50 border border-cream-200 rounded-2xl px-6 py-5 shadow-warm-sm">
      <div>
        <p class="text-warm-gray-900 font-semibold">Questions or custom requests?</p>
        <p class="text-warm-gray-700 text-sm">Call us or book online — we’re happy to recommend the right service.</p>
      </div>
      <div class="flex items-center gap-3">
        <%= render 'shared/cta_button',
                   text: 'Book Online',
                   href: booking_link,
                   style: :solid,
                   size: :md,
                   icon: 'calendar-days' %>
        <%= render 'shared/cta_button',
                   text: 'Call the Salon',
                   href: 'tel:+17048249032',
                   style: :outline,
                   size: :sm,
                   icon: 'phone' %>
      </div>
    </div>
  </div>
</section>
