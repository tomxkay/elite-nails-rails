<!-- ===== SAFETY & CLEANLINESS SECTION ===== -->
<section class="relative overflow-hidden bg-gradient-to-r from-cream-50 via-peach-50 to-cream-50 py-24 lg:py-28">
  <!-- ambient backdrop -->
  <div class="pointer-events-none absolute inset-0 hero-grid-lines opacity-30" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 rounded-3xl border border-cream-200 shadow-warm-sm bg-cream-50/90 backdrop-blur">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 items-center px-6 py-10">
      <div class="md:col-span-2 max-w-3xl">
        <%= render 'shared/section_header',
                   eyebrow: 'Cleanliness & Care',
                   title: 'Your Safety Comes First',
                   subtitle: 'Sanitized tools, fresh liners for every service, and stations cleaned between guests. The small things, done every time.' ,
                   align: :left %>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm text-warm-gray-700">
          <div class="flex items-start gap-2">
            <%= icon 'check-badge', classes: 'w-5 h-5 text-terracotta-600 mt-0.5' %>
            <span>Fresh liners and sanitized bowls every guest</span>
          </div>
          <div class="flex items-start gap-2">
            <%= icon 'shield-check', classes: 'w-5 h-5 text-terracotta-600 mt-0.5' %>
            <span>Tools and stations disinfected between guests</span>
          </div>
          <div class="flex items-start gap-2">
            <%= icon 'heart', classes: 'w-5 h-5 text-terracotta-600 mt-0.5' %>
            <span>Friendly technicians trained for gentle, hygienic care</span>
          </div>
        </div>
      </div>
      <div class="bg-gradient-to-br from-peach-100 via-cream-100 to-white rounded-2xl p-6 text-center border border-cream-200 shadow-warm-sm">
        <p class="text-terracotta-700 font-semibold mb-2">Family-owned in Cramerton</p>
        <p class="text-sm text-warm-gray-700">Next to Market Street favorites — walk in, call, or book online.</p>
        <div class="mt-4 flex flex-col gap-2">
          <%= render 'shared/cta_button',
                     text: 'Call the Salon',
                     href: "tel:#{salon.phone}",
                     style: :outline,
                     size: :md,
                     icon: 'phone' %>
          <%= render 'shared/cta_button',
                     text: 'Book Online',
                     href: booking_link,
                     style: :solid,
                     size: :md,
                     icon: 'calendar-days' %>
        </div>
      </div>
    </div>
  </div>
</section>
