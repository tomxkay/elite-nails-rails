<!-- ===== OUR STORY SECTION ===== -->
<section id="story" class="relative flex items-center overflow-hidden bg-gradient-to-b from-cream-50 via-peach-50 to-cream-50 lg:min-h-[85vh] py-24 lg:py-32">
  <!-- ambient backdrop -->
  <div class="pointer-events-none absolute inset-0 hero-grid-lines opacity-30" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-10">
    <div class="grid grid-cols-1 items-center gap-14 lg:grid-cols-2 lg:gap-20">

      <%# ===== Photo column (blended arched frame on ambient backdrop) ===== %>
      <div class="relative order-1 flex justify-center"
           data-controller="scroll-reveal"
           data-scroll-reveal-animation-value="fadeInLeft">
        <%# soft color blob behind %>
        <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
          <div class="h-[80%] w-[80%] rounded-full portrait-backdrop-terra blur-2xl"></div>
        </div>
        <%# oversized watermark %>
        <span class="pointer-events-none absolute select-none font-script leading-none text-[9rem] lg:text-[12rem] text-warm-gray-900/[0.05]" aria-hidden="true">est.</span>

        <div class="relative">
          <div class="relative z-10 h-[58vh] max-h-[560px] w-[clamp(16rem,34vw,24rem)] overflow-hidden rounded-t-[999px] rounded-b-[2.5rem] ring-1 ring-cream-200 shadow-warm-xl">
            <%= image_tag "salon-interior.webp",
                          alt: "Inside the Elite Nails salon",
                          class: "h-full w-full object-cover saturate-[1.08]",
                          loading: "lazy",
                          decoding: "async",
                          width: 380,
                          height: 373 %>
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-warm-gray-900/20 via-transparent to-transparent"></div>
          </div>

          <%# ground shadow %>
          <div class="portrait-ground pointer-events-none absolute -bottom-4 left-1/2 h-14 w-[72%] -translate-x-1/2 blur-md" aria-hidden="true"></div>

          <%# floating badge %>
          <div class="absolute -bottom-6 left-2 z-20 lg:-left-8 rounded-2xl border border-cream-200 bg-cream-50/95 px-6 py-4 shadow-warm-lg backdrop-blur">
            <p class="font-script text-lg text-terracotta-700">Since 2002</p>
            <p class="text-xs text-warm-gray-700">Rooted in the Cramerton community</p>
          </div>
        </div>
      </div>

      <%# ===== Narrative column ===== %>
      <div class="order-2"
           data-controller="scroll-reveal"
           data-scroll-reveal-animation-value="fadeInRight"
           data-scroll-reveal-delay-value="0.15">

        <div class="flex items-center gap-4">
          <span class="h-px w-16 bg-gradient-to-r from-terracotta-300 to-transparent"></span>
          <span class="text-xs uppercase tracking-[0.24em] text-terracotta-600">Family-Owned &amp; Local</span>
        </div>

        <h2 class="mt-6 font-serif text-4xl leading-tight text-warm-gray-900 sm:text-5xl lg:text-6xl">Our story</h2>

        <p class="mt-8 font-script text-2xl leading-snug text-warm-gray-700 lg:text-3xl">
          &ldquo;Come as you are. Leave feeling polished and cared for.&rdquo;
        </p>

        <div class="mt-6 max-w-xl space-y-4 leading-relaxed text-warm-gray-700">
          <p>
            We're a family-owned salon that believes nail care should feel personal,
            calming, and a little luxurious. Every guest is greeted by name, offered
            a cozy seat, and treated with the same attention we'd give our own family.
          </p>
          <p>
            Our promise: spotless cleanliness, honest recommendations, and technicians
            who listen first. We've been proud to serve Cramerton, Belmont, and Gaston
            County since 2002 &mdash; and we can't wait to welcome you.
          </p>
        </div>

        <div class="mt-8 flex items-center gap-4">
          <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-peach-200 to-cream-100 shadow-warm-sm">
            <%= icon 'hand-raised', classes: 'w-7 h-7 text-terracotta-600' %>
          </div>
          <p class="font-script text-xl text-terracotta-700">&mdash; The Elite Nails Family</p>
        </div>
      </div>

    </div>
  </div>
</section>
