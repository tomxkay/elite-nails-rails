<!-- ===== TEAM SECTION ===== -->
<section id="team" class="relative overflow-hidden bg-cream-50">
  <!-- ambient backdrop -->
  <div class="pointer-events-none absolute inset-0 hero-grid-lines opacity-40" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-20 lg:pt-24">
    <%= render 'shared/section_header',
               eyebrow: 'Meet Your Technicians',
               title: 'Friendly, Skilled, and Neighborly',
               subtitle: 'Small team, big heart. We listen first, recommend honestly, and care about every detail.' %>

    <%# Who takes online bookings is derived from the `bookable` flag, never
        hardcoded — technicians are expected to opt in over time and this line
        has to stay true without anyone remembering to edit it. Hidden when
        every tech is bookable (nothing to explain) or none are (the site has
        no online booking to speak of). See docs/booking-adoption-notes.md. %>
    <% team = TeamMember.for_display %>
    <% online_names = team.select(&:bookable).map(&:name) %>
    <% phone_names = team.reject(&:bookable).map(&:name) %>
    <% if online_names.any? && phone_names.any? %>
      <p class="mx-auto mt-6 flex max-w-2xl flex-wrap items-center justify-center gap-x-2 gap-y-1 text-center text-sm text-warm-gray-600">
        <%= icon 'phone', classes: 'h-4 w-4 text-terracotta-400', 'aria-hidden': true %>
        <span>
          <%= online_names.to_sentence %>
          <%= online_names.one? ? 'takes' : 'take' %> online bookings. To book with
          <%= phone_names.to_sentence(two_words_connector: ' or ', last_word_connector: ', or ') %>,
          give us a call at
          <a href="tel:<%= salon.phone %>" class="font-medium text-terracotta-600 underline underline-offset-4"><%= salon.phone_display %></a>.
        </span>
      </p>
    <% end %>
  </div>

  <%# Content from the DB (TeamMember), with in-code DEFAULTS fallback.
      image_url stays nil until real photos land (renders the cutout placeholder). %>
  <div class="relative z-10 mx-auto mt-10 max-w-7xl px-4 pb-20 sm:px-6 lg:px-8 lg:pb-24">
    <div class="max-h-[46rem] overflow-y-auto pr-1 lg:max-h-none lg:overflow-visible lg:pr-0">
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        <% team.each_with_index do |member, i| %>
          <%= render 'shared/team_member',
                     name: member.name,
                     role: member.role,
                     bio: member.bio,
                     quote: member.quote,
                     specialties: member.specialties,
                     bookable: member.bookable,
                     image_url: (asset_path(member.image) if member.image.present?),
                     index: i %>
        <% end %>
      </div>
    </div>
  </div>
</section>
