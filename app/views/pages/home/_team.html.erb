<!-- ===== TEAM SECTION ===== -->
<section id="team" class="relative overflow-hidden bg-cream-50">
  <!-- ambient backdrop -->
  <div class="pointer-events-none absolute inset-0 hero-grid-lines opacity-40" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-24 lg:pt-28">
    <%= render 'shared/section_header',
               eyebrow: 'Meet Your Technicians',
               title: 'Friendly, Skilled, and Neighborly',
               subtitle: 'Small team, big heart. We listen first, recommend honestly, and care about every detail.' %>
  </div>

  <%# Content from the DB (TeamMember), with in-code DEFAULTS fallback.
      image_url stays nil until real photos land (renders the cutout placeholder). %>
  <div class="relative z-10 mt-8 divide-y divide-cream-200/70">
    <% TeamMember.for_display.each_with_index do |member, i| %>
      <%= render 'shared/team_member',
                 name: member.name,
                 role: member.role,
                 bio: member.bio,
                 quote: member.quote,
                 specialties: member.specialties,
                 bookable: member.bookable,
                 image_url: (asset_path(member.image) if member.image.present?),
                 index: i %>
    <% end %>
  </div>
</section>
