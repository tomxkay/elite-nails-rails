<!-- ===== TEAM SECTION ===== -->
<section id="team" class="py-24 lg:py-28 bg-sage-50/60">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <%= render 'shared/section_header',
               eyebrow: 'Meet Your Technicians',
               title: 'Friendly, Skilled, and Neighborly',
               subtitle: 'Small team, big heart. We listen first, recommend honestly, and care about every detail.' %>

    <% team = [
      { name: "Linh Tran", role: "Owner & Lead Nail Artist", bio: "Specializes in gel, dip, and fine-line nail art. Known for a gentle touch and calming demeanor.", specialties: ["Gel Art", "Dip Powder", "Fine Line"] },
      { name: "Maya Lopez", role: "Senior Technician", bio: "Loves creative color palettes and spa pedicures. Guests rave about her relaxing massages.", specialties: ["Spa Pedicure", "Color Pairing", "Massage"] },
      { name: "Kim Nguyen", role: "Nail Technician", bio: "Precise shaping and durable acrylics with a friendly, welcoming vibe.", specialties: ["Acrylics", "Nail Shaping", "Natural Looks"] }
    ] %>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6">
      <% team.each do |member| %>
        <%= render 'shared/team_member', **member %>
      <% end %>
    </div>
  </div>
</section>
